generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
  OWNER
}

enum PropertyType {
  HOTEL
  VILLA
  RESORT
  APARTMENT
  HOMESTAY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id        Int       @id @default(autoincrement())
  fullName  String
  email     String    @unique
  password  String
  role      UserRole  @default(CUSTOMER)
  createdAt DateTime  @default(now())

  bookings  Booking[]
}

model Property {
  id           Int          @id @default(autoincrement())
  name         String
  description  String?
  propertyType PropertyType
  address      String?
  city         String?
  country      String?

  rooms        Room[]

  createdAt    DateTime @default(now())
}

model Room {
  id          Int      @id @default(autoincrement())
  propertyId  Int
  name        String
  description String?
  price       Decimal  @db.Decimal(12,2)
  capacity    Int

  property    Property @relation(fields: [propertyId], references: [id])
  bookings    Booking[]
}

model Booking {
  id          Int            @id @default(autoincrement())
  userId      Int
  roomId      Int

  checkIn     DateTime
  checkOut    DateTime

  totalAmount Decimal        @db.Decimal(12,2)

  status      BookingStatus  @default(PENDING)

  user        User           @relation(fields: [userId], references: [id])
  room        Room           @relation(fields: [roomId], references: [id])

  createdAt   DateTime       @default(now())
}
