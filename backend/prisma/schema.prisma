generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  FINANCE_HEAD
  CUSTOMER
  OWNER
}

enum PropertyType {
  HOTEL
  VILLA
  RESORT
  APARTMENT
  HOMESTAY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        Int       @id @default(autoincrement())
  fullName  String
  email     String    @unique
  password  String
  role      UserRole  @default(CUSTOMER)
  department String?
  jobTitle   String?
  phone      String?
  avatarUrl  String?
  bio        String?
  socialLinks Json?
  createdAt DateTime  @default(now())

  bookings  Booking[]
  bookingAuditLogs BookingAuditLog[] @relation("BookingAuditActor")
  requestedBookingChanges BookingChangeRequest[] @relation("BookingChangeRequestedBy")
  reviewedBookingChanges  BookingChangeRequest[] @relation("BookingChangeReviewedBy")
}

model Property {
  id           Int          @id @default(autoincrement())
  name         String
  description  String?
  propertyType PropertyType
  address      String?
  city         String?
  country      String?

  rooms        Room[]

  createdAt    DateTime @default(now())
}

model Room {
  id          Int      @id @default(autoincrement())
  propertyId  Int
  name        String
  description String?
  price       Decimal  @db.Decimal(12,2)
  capacity    Int

  property    Property @relation(fields: [propertyId], references: [id])
  bookings    Booking[]
}

model Booking {
  id          Int            @id @default(autoincrement())
  userId      Int
  roomId      Int

  checkIn     DateTime
  checkOut    DateTime

  totalAmount Decimal        @db.Decimal(12,2)

  status      BookingStatus  @default(PENDING)

  user        User           @relation(fields: [userId], references: [id])
  room        Room           @relation(fields: [roomId], references: [id])

  auditLogs   BookingAuditLog[]
  changeRequests BookingChangeRequest[]

  createdAt   DateTime       @default(now())
}

model BookingAuditLog {
  id          Int      @id @default(autoincrement())
  bookingId   Int
  actorUserId Int?

  action      String
  reason      String?
  oldData     Json?
  newData     Json?

  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  actor       User?    @relation("BookingAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())

  @@index([bookingId])
  @@index([actorUserId])
  @@index([createdAt])
}

model BookingChangeRequest {
  id            Int            @id @default(autoincrement())
  bookingId     Int
  requestedById Int?
  reviewedById  Int?

  status        ApprovalStatus @default(PENDING)
  action        String
  reason        String
  reviewNote    String?
  oldData       Json?
  newData       Json

  booking       Booking        @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  requestedBy   User?          @relation("BookingChangeRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  reviewedBy    User?          @relation("BookingChangeReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  reviewedAt    DateTime?
  createdAt     DateTime       @default(now())

  @@index([bookingId])
  @@index([requestedById])
  @@index([reviewedById])
  @@index([status])
  @@index([createdAt])
}
