generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  FINANCE_HEAD
  CUSTOMER
  OWNER
}

enum PropertyType {
  HOTEL
  VILLA
  RESORT
  APARTMENT
  HOMESTAY
  CO_LIVING
}

enum RentalTerm {
  DAILY
  MONTHLY
  YEARLY
}

enum BedroomType {
  STUDIO
  ONE_BR
  TWO_BR
  THREE_BR_PLUS
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AvailabilityBlockType {
  MAINTENANCE
  OWNER_USE
  HOLD
  OTHER
}

enum HousekeepingStatus {
  CLEAN
  DIRTY
  INSPECTING
  OUT_OF_SERVICE
}

model User {
  id        Int       @id @default(autoincrement())
  fullName  String
  email     String    @unique
  password  String
  role      UserRole  @default(CUSTOMER)
  department String?
  jobTitle   String?
  phone      String?
  avatarUrl  String?
  bio        String?
  socialLinks Json?
  createdAt DateTime  @default(now())

  bookings  Booking[]
  bookingAuditLogs BookingAuditLog[] @relation("BookingAuditActor")
  requestedBookingChanges BookingChangeRequest[] @relation("BookingChangeRequestedBy")
  reviewedBookingChanges  BookingChangeRequest[] @relation("BookingChangeReviewedBy")
  availabilityBlocks AvailabilityBlock[] @relation("AvailabilityBlockCreatedBy")
}

model Property {
  id           Int          @id @default(autoincrement())
  name         String
  slug         String?      @unique
  description  String?
  propertyType PropertyType
  supportedRentalTerms RentalTerm[] @default([DAILY])
  destinationId Int?
  timezone     String       @default("Asia/Jakarta")
  currency     String       @default("IDR")
  address      String?
  fullAddress  String?
  city         String?
  country      String?
  area         String?
  latitude     Decimal?     @db.Decimal(10,7)
  longitude    Decimal?     @db.Decimal(10,7)
  buildingName String?
  gallery      Json?
  propertyFacilities Json?
  buildingFacilities Json?
  additionalInfo String?
  rating       Decimal      @default(0) @db.Decimal(3,2)
  reviewCount  Int          @default(0)
  isPublished  Boolean      @default(true)

  destination  Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  allotments   Allotment[]
  rooms        Room[]
  roomTypes    RoomType[]

  createdAt    DateTime @default(now())

  @@index([destinationId])
  @@index([propertyType])
  @@index([city])
  @@index([country])
  @@index([isPublished])
}

model Destination {
  id          Int        @id @default(autoincrement())
  country     String
  city        String
  slug        String     @unique
  displayName String
  latitude    Decimal?   @db.Decimal(10,7)
  longitude   Decimal?   @db.Decimal(10,7)
  active      Boolean    @default(true)

  properties  Property[]

  createdAt   DateTime   @default(now())

  @@index([country])
  @@index([city])
  @@index([active])
}

model RoomType {
  id             Int                 @id @default(autoincrement())
  propertyId     Int
  name           String
  bedroomType    BedroomType?
  description    String?
  capacity       Int
  totalRooms     Int                 @default(0)
  basePrice      Decimal?            @db.Decimal(12,2)
  gallery         Json?
  unitFacilities  Json?

  property       Property            @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  rooms          Room[]
  allotments     Allotment[]
  dailyAvailability DailyAvailability[]

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([propertyId])
  @@index([bedroomType])
}

model Room {
  id          Int      @id @default(autoincrement())
  propertyId  Int
  roomTypeId  Int?
  name        String
  description String?
  price       Decimal  @db.Decimal(12,2)
  capacity    Int
  tower       String?
  floor       String?
  electricityWatt Int?
  gallery     Json?
  unitFacilities Json?
  additionalInfo String?
  housekeepingStatus HousekeepingStatus @default(CLEAN)

  property    Property @relation(fields: [propertyId], references: [id])
  roomType    RoomType? @relation(fields: [roomTypeId], references: [id], onDelete: SetNull)
  bookings    Booking[]
  roomAllocations RoomAllocation[]
  availabilityBlocks AvailabilityBlock[]

  @@index([propertyId])
  @@index([roomTypeId])
}

model Booking {
  id          Int            @id @default(autoincrement())
  userId      Int
  roomId      Int

  checkIn     DateTime
  checkOut    DateTime

  totalAmount Decimal        @db.Decimal(12,2)

  status      BookingStatus  @default(PENDING)

  user        User           @relation(fields: [userId], references: [id])
  room        Room           @relation(fields: [roomId], references: [id])

  auditLogs   BookingAuditLog[]
  changeRequests BookingChangeRequest[]
  roomAllocations RoomAllocation[]

  createdAt   DateTime       @default(now())

  @@index([roomId])
  @@index([checkIn])
  @@index([checkOut])
}

model BookingAuditLog {
  id          Int      @id @default(autoincrement())
  bookingId   Int
  actorUserId Int?

  action      String
  reason      String?
  oldData     Json?
  newData     Json?

  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  actor       User?    @relation("BookingAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())

  @@index([bookingId])
  @@index([actorUserId])
  @@index([createdAt])
}

model BookingChangeRequest {
  id            Int            @id @default(autoincrement())
  bookingId     Int
  requestedById Int?
  reviewedById  Int?

  status        ApprovalStatus @default(PENDING)
  action        String
  reason        String
  reviewNote    String?
  oldData       Json?
  newData       Json

  booking       Booking        @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  requestedBy   User?          @relation("BookingChangeRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  reviewedBy    User?          @relation("BookingChangeReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  reviewedAt    DateTime?
  createdAt     DateTime       @default(now())

  @@index([bookingId])
  @@index([requestedById])
  @@index([reviewedById])
  @@index([status])
  @@index([createdAt])
}

model AvailabilityBlock {
  id          Int                   @id @default(autoincrement())
  roomId      Int
  startDate   DateTime
  endDate     DateTime
  type        AvailabilityBlockType @default(OTHER)
  reason      String?
  createdById Int?

  room        Room                  @relation(fields: [roomId], references: [id], onDelete: Restrict)
  createdBy   User?                 @relation("AvailabilityBlockCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt   DateTime              @default(now())

  @@index([roomId])
  @@index([createdById])
  @@index([startDate])
  @@index([endDate])
}

model Allotment {
  id          Int       @id @default(autoincrement())
  propertyId  Int
  roomTypeId  Int
  date        DateTime
  totalRooms  Int
  closed      Boolean   @default(false)
  rate        Decimal?  @db.Decimal(12,2)
  minStay     Int?
  maxStay     Int?

  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  roomType    RoomType  @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([date, roomTypeId])
  @@index([propertyId])
  @@index([roomTypeId])
  @@index([date])
}

model RoomAllocation {
  id          Int      @id @default(autoincrement())
  bookingId   Int
  roomId      Int
  date        DateTime
  notes       String?

  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Restrict)

  createdAt   DateTime @default(now())

  @@unique([bookingId, date])
  @@unique([roomId, date])
  @@index([bookingId])
  @@index([roomId])
  @@index([date])
}

model DailyAvailability {
  id             Int      @id @default(autoincrement())
  roomTypeId     Int
  date           DateTime
  totalRooms     Int
  bookedRooms    Int      @default(0)
  blockedRooms   Int      @default(0)
  availableRooms Int

  roomType       RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  updatedAt      DateTime @updatedAt

  @@unique([date, roomTypeId])
  @@index([roomTypeId])
  @@index([date])
}
